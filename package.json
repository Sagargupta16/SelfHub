{
  "name": "selfhub-mcp-server",
  "version": "0.2.0",
  "description": "Personal MCP-powered digital hub - private data center with AI integration for memory, notes, and personal knowledge management",
  "main": "build/index.js",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsx watch src/index.ts",
    "start": "node build/index.js",
    "prepare": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/seed.ts",
    "clean": "rimraf build",
    "reset": "pnpm clean && pnpm build",
    "quick-start": "pnpm build && pnpm seed && pnpm start"
  },
  "keywords": [
    "mcp",
    "model-context-protocol"
  ],
  "author": "Sagar Gupta",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "dotenv": "^17.2.3",
    "mongoose": "^9.1.6"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": ">=3.2.0",
      "ip-address": ">=10.1.1"
    }
  }
}